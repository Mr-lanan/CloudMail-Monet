{
  "name": "mail-worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --config wrangler-dev.toml",
    "test": "wrangler deploy --config wrangler-test.toml",
    "deploy": "pnpm run build:web && wrangler deploy",
    "start": "wrangler dev",
    "build:web": "pnpm --prefix ../mail-vue install --frozen-lockfile && pnpm --prefix ../mail-vue run build"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.7.5",
    "vitest": "~3.0.7",
    "wrangler": "^4.110.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.882.0",
    "@aws-sdk/client-sesv2": "^3.1087.0",
    "@cloudflare/vite-plugin": "1.6.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.42.0",
    "hono": "^4.7.5",
    "i18next": "^25.3.2",
    "linkedom": "^0.18.10",
    "postal-mime": "^2.4.3",
    "resend": "^6.4.1",
    "ua-parser-js": "^2.0.3",
    "uuid": "^11.1.0"
  },
  "packageManager": "pnpm@10.12.1"
}
